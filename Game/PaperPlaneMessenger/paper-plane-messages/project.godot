; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PaperPlaneMessenger"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

WindowManager="*uid://xeuehp5b2kqw"
MousePassthroughManager="*uid://fuop4t3clvxe"
WebSocketManager="*uid://dcqinwhfwy2yy"
AuthManager="*uid://kpbeq7ptnbdu"
FriendManager="*uid://cm0o0okbdq64c"

[display]

window/size/mode=2
window/size/borderless=true
window/size/always_on_top=true
window/size/transparent=true
window/per_pixel_transparency/allowed=true

[dotnet]

project/assembly_name="PaperPlaneMessages"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
anti_aliasing/quality/msaa_3d=1
environment/defaults/default_clear_color=Color(0.3019608, 0.3019608, 0.3019608, 0)
